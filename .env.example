# --- Database ---
DATABASE_URL=postgresql://idp_user:idp_password@localhost:5432/idp_db

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- LLM ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-2.5-flash

# --- OCR ---
OCR_PROVIDER=tesseract   # tesseract | textract | document_ai

# --- Storage ---
STORAGE_BACKEND=local    # local | b2
RAW_STORAGE_PATH=storage/raw
REDACTED_STORAGE_PATH=storage/redacted

# --- Backblaze B2 (only needed when STORAGE_BACKEND=b2) ---
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
B2_KEY_ID=your_backblaze_keyid_here
B2_APPLICATION_KEY=your_backblaze_applicationkey_here
B2_BUCKET_NAME=your_bucket_name_here

# --- App ---
CONFIDENCE_THRESHOLD=0.80
MAX_FILE_SIZE_MB=20
LOG_LEVEL=INFO

# --- Public deployment safety ---
ADMIN_API_KEY=set_a_long_random_string_here
ALLOWED_ORIGINS=*
RATE_LIMIT_UPLOADS=5/hour
